# Runtime stays local until the joint real-site validation is approved.
AUTOMATION_MODE=rehearsal
AUTOMATION_DATA_DIR=./data
AUTOMATION_ARTIFACT_DIR=./output/runs
AUTOMATION_PROFILE_DIR=./data/profiles
AUTOMATION_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
AUTOMATION_EXTERNAL_READ=false
AUTOMATION_EXTERNAL_EXECUTION=false
# Select the known FRP model configuration. Remove this line to use explicit LOCAL_LLM_* values.
AUTOMATION_MODEL_PROFILE=frp_qwen_vision

# Local OpenAI-compatible multimodal model.
LOCAL_LLM_BASE_URL=http://49.235.153.151:6081/v1
# When AUTOMATION_MODEL_PROFILE is set, use this optional STCP-local override on the worker.
# AUTOMATION_MODEL_BASE_URL_OVERRIDE=http://127.0.0.1:16081/v1
LOCAL_LLM_API_KEY=local
LOCAL_LLM_MODEL=C:\\Users\\666\\Downloads\\Qwen3.5-9B.Q4_K_M.gguf
LOCAL_LLM_MAX_TOKENS=2048
LOCAL_LLM_TEMPERATURE=0
LOCAL_LLM_HAS_VISION=true

# `remote_url` is appropriate when the model server can retrieve screenshots from the image host.
# Configure one publisher below; do not expose customer PII on a public image host.
LOCAL_LLM_IMAGE_TRANSPORT=remote_url
# When AUTOMATION_MODEL_PROFILE is set, use this optional override to select http_upload or inline_data_url.
# AUTOMATION_IMAGE_TRANSPORT_OVERRIDE=http_upload
AUTOMATION_IMAGE_PUBLIC_BASE_URL=http://49.235.153.151:8080/automation
# AUTOMATION_IMAGE_PUBLISH_DIR=/path/to/the/nginx/served/automation/directory
# Or use an upload service:
# AUTOMATION_IMAGE_UPLOAD_URL=https://image-host.example/upload
# AUTOMATION_IMAGE_UPLOAD_FIELD=file
# AUTOMATION_IMAGE_UPLOAD_RESPONSE_PATH=url
# AUTOMATION_IMAGE_UPLOAD_BEARER_TOKEN=

# Run this ingress only on the model computer. Keep it loopback-bound; a Windows FRP STCP visitor
# exposes it locally to the worker without opening an image upload port to the public internet.
AUTOMATION_IMAGE_INGRESS_HOST=127.0.0.1
AUTOMATION_IMAGE_INGRESS_PORT=8090
AUTOMATION_IMAGE_INGRESS_DATA_DIR=./data/image-ingress
AUTOMATION_IMAGE_INGRESS_FIELD=file
AUTOMATION_IMAGE_INGRESS_TTL_SECONDS=300
AUTOMATION_IMAGE_INGRESS_MAX_BYTES=6291456
# The model process must be able to retrieve this loopback URL on the model computer.
AUTOMATION_IMAGE_INGRESS_MODEL_READ_BASE_URL=http://127.0.0.1:8090/v1/images
AUTOMATION_IMAGE_INGRESS_UPLOAD_TOKEN=

# Set during the joint validation after the dedicated browser profile is ready.
TIKTOK_SELLER_BASE_URL=
HCRD_BASE_URL=http://124.156.202.7:8888/wms-main
HCRD_INVENTORY_PATH=/inventory/inventory/listForClientAction.json
HCRD_INVENTORY_PAGE_SIZE=200
HCRD_INVENTORY_MAX_PAGES=100
# Keep enabled: the API is the source of truth, while the multimodal model cross-checks visible rows.
HCRD_INVENTORY_VISUAL_AUDIT=true
# If JSESSIONID is a browser-session cookie, keep the worker browser open while the operator logs in.
HCRD_AUTH_WAIT_SECONDS=300
HCRD_USERNAME=
HCRD_PASSWORD=
ECHOTIK_BASE_URL=https://echotik.live
MAIL_BASE_URL=https://mail.google.com

# Store-manager Windows PC: bind this service to its LAN IPv4 address, never to a public address.
# Generate the token locally with: openssl rand -hex 32
# AUTOMATION_SERVICE_HOST=192.168.x.x
AUTOMATION_SERVICE_PORT=8010
AUTOMATION_SERVICE_REQUIRE_TOKEN=true
AUTOMATION_SERVICE_TOKEN=
# These values belong on the monitoring computer only; use the LAN address above and the same token.
# AUTOMATION_REMOTE_ENDPOINT=http://192.168.x.x:8010
# AUTOMATION_REMOTE_TOKEN=
# AUTOMATION_MONITOR_DOWNLOAD_DIR=./output/remote-monitor
AUTOMATION_WORKER_POLL_MS=1500
AUTOMATION_WORKER_LEASE_MS=900000
